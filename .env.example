# WenShanKB 环境变量模板
# 复制为 .env 并填入真实值

# ── 数据库 ──
DATABASE_URL=postgresql+asyncpg://kb_user:kb_pass@db:5432/wenshan_kb
DATABASE_URL_SYNC=postgresql://kb_user:kb_pass@db:5432/wenshan_kb

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── 安全 ──
SECRET_KEY=change-this-to-a-random-string-64-chars
AGENT_API_KEY=wskb-agent-change-this

# ── AI (DeepSeek Chat) ──
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── 向量嵌入 (可独立于 Chat 配置) ──
# SiliconFlow 提供免费 embedding: https://siliconflow.cn
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
LLM_MODEL=deepseek-chat
# 向量嵌入模型（DeepSeek 暂无 embedding API，可用 OpenAI 或其他兼容服务）
EMBEDDING_MODEL=text-embedding-3-small

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── 数据库密码 ──
DB_PASSWORD=kb_pass
